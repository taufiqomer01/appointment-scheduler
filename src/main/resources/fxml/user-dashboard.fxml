<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.scheduler.controller.UserDashboardController"
            styleClass="dashboard">
    
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <Label fx:id="welcomeLabel" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="logout-button"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="25" styleClass="content">
                <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>
                
                <!-- Statistics Cards -->
                <HBox spacing="20">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Appointments" styleClass="stat-label"/>
                        <Label fx:id="totalAppointmentsLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="Upcoming" styleClass="stat-label"/>
                        <Label fx:id="upcomingLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="Completed" styleClass="stat-label"/>
                        <Label fx:id="completedLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                
                <!-- Book Appointment Section -->
                <VBox spacing="15" styleClass="card">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    
                    <Text text="Book New Appointment" styleClass="section-title"/>
                    
                    <GridPane hgap="15" vgap="12" maxWidth="700">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        
                        <Label text="Select Staff *" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <ComboBox fx:id="staffComboBox" onAction="#handleStaffSelected" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" promptText="Choose a staff member"/>
                        
                        <Label text="Date *" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <DatePicker fx:id="datePicker" onAction="#handleDateSelected" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" promptText="Select date"/>
                        
                        <Label text="Available Slots *" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <ListView fx:id="slotsListView" prefHeight="150" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        
                        <Label text="Notes" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                        <TextArea fx:id="notesArea" prefRowCount="3" promptText="Optional notes" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        
                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <Button text="Book Appointment" onAction="#handleBookAppointment" styleClass="primary-button"/>
                        </HBox>
                    </GridPane>
                </VBox>
                
                <!-- Appointments Table Section -->
                <VBox spacing="15" styleClass="card">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Text text="My Appointments" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Search appointments..." prefWidth="250"/>
                    </HBox>
                    
                    <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="staffColumn" text="Staff" prefWidth="180" sortable="true"/>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" sortable="true"/>
                            <TableColumn fx:id="timeColumn" text="Time" prefWidth="100" sortable="true"/>
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="130" sortable="true"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    
                    <HBox spacing="12">
                        <Button text="Edit Appointment" onAction="#handleEditAppointment" styleClass="secondary-button"/>
                        <Button text="Cancel Appointment" onAction="#handleCancelAppointment" styleClass="danger-button"/>
                        <Button text="Submit Review" onAction="#handleSubmitReview" styleClass="success-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

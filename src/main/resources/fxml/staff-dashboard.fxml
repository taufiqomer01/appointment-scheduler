<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.scheduler.controller.StaffDashboardController"
            styleClass="dashboard">
    
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <Label fx:id="welcomeLabel" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="logout-button"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="25" styleClass="content">
                <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>
                
                <!-- Statistics Cards -->
                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>
                    
                    <VBox styleClass="stat-card" GridPane.columnIndex="0">
                        <Label text="Total Appointments" styleClass="stat-label"/>
                        <Label fx:id="totalAppointmentsLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    
                    <VBox styleClass="stat-card" GridPane.columnIndex="1">
                        <Label text="Today's Schedule" styleClass="stat-label"/>
                        <Label fx:id="todayAppointmentsLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    
                    <VBox styleClass="stat-card" GridPane.columnIndex="2">
                        <Label text="Completed" styleClass="stat-label"/>
                        <Label fx:id="completedLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    
                    <VBox styleClass="stat-card" GridPane.columnIndex="3">
                        <Label text="Avg Rating" styleClass="stat-label"/>
                        <Label fx:id="avgRatingLabel" text="0.0" styleClass="stat-value"/>
                    </VBox>
                </GridPane>
                
                <!-- Appointments Table Section -->
                <VBox spacing="15" styleClass="card">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Text text="My Appointments" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Search appointments..." prefWidth="250"/>
                    </HBox>
                    
                    <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="userColumn" text="User" prefWidth="180" sortable="true"/>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" sortable="true"/>
                            <TableColumn fx:id="timeColumn" text="Time" prefWidth="100" sortable="true"/>
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="130" sortable="true"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Update Status:" styleClass="form-label"/>
                        <ComboBox fx:id="statusComboBox" prefWidth="180" promptText="Select status"/>
                        <Button text="Update" onAction="#handleUpdateStatus" styleClass="primary-button"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="View Details" onAction="#handleViewDetails" styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

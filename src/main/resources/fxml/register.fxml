<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.scheduler.controller.RegisterController"
      alignment="CENTER" spacing="15" styleClass="login-container">
    
    <padding>
        <Insets top="30" right="50" bottom="30" left="50"/>
    </padding>
    
    <Text text="Create Account" styleClass="title"/>
    
    <VBox spacing="8" maxWidth="350">
        <Label text="Full Name *"/>
        <TextField fx:id="nameField" promptText="Enter your full name"/>
        
        <Label text="Username *"/>
        <TextField fx:id="usernameField" promptText="Choose a username"/>
        
        <Label text="Email *"/>
        <TextField fx:id="emailField" promptText="Enter your email"/>
        
        <Label text="Phone"/>
        <TextField fx:id="phoneField" promptText="Enter phone number"/>
        
        <Label text="Password *"/>
        <PasswordField fx:id="passwordField" promptText="Create password"/>
        
        <Label text="Confirm Password *"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>
        
        <Label fx:id="errorLabel" styleClass="error-label"/>
        
        <Button text="Register" onAction="#handleRegister" styleClass="primary-button" maxWidth="Infinity"/>
        <Button text="Back to Login" onAction="#handleBackToLogin" styleClass="secondary-button" maxWidth="Infinity"/>
    </VBox>
</VBox>
